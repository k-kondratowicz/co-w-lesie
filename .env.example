DATABASE_URL="postgresql://postgres:postgres@localhost:54322/cowlesie"

# Shared secret the scheduler sends as "Authorization: Bearer <CRON_SECRET>" to /api/cron/*
CRON_SECRET="change-me"

# Error monitoring (Sentry). DSN is public (safe to expose); set it to activate in production.
# NEXT_PUBLIC_SENTRY_DSN="https://<key>@o000000.ingest.sentry.io/000000"
# Optional - only needed to upload source maps during build (cleaner stack traces):
# SENTRY_ORG="your-org"
# SENTRY_PROJECT="co-w-lesie"
# SENTRY_AUTH_TOKEN="sntrys_..."

# Rate limiting: set both to use Upstash Redis (durable, shared). Unset -> in-memory fallback.
# UPSTASH_REDIS_REST_URL="https://<your-db>.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="<token>"

# Forest PMTiles layer. Defaults to the country-wide R2 file; for local testing copy the file to
# public/ and use a same-origin relative path (works on any dev port, no CORS).
# Built via: npm run build:forest-pmtiles.
NEXT_PUBLIC_FOREST_PMTILES_URL="https://<your-account>.r2.dev/poland_forests.pmtiles"

# SEO
NEXT_PUBLIC_SEO_TITLE="Co w lesie"
NEXT_PUBLIC_SEO_DESCRIPTION="Mapa zgłoszeń i bezpieczeństwa w polskich lasach. Sprawdź zagrożenie pożarowe i zakazy wstępu, zanim wejdziesz do lasu."
NEXT_PUBLIC_SITE_DESCRIPTION_SHORT="Mapa zgłoszeń i bezpieczeństwa w polskich lasach."

# Google
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION="<google-site-verification-token>"

# Salt for hashing the per-visitor vote fingerprint. Generate: openssl rand -hex 16
VOTE_SALT="change-me"

# R2 for report photos. Not critical, so defaults to null (no images) if not set up.
NEXT_PUBLIC_R2_PUBLIC_URL="https://<your-account>.r2.dev"
R2_ACCOUNT_ID="<r2-account-id>"
R2_ACCESS_KEY_ID="<r2-access-key-id>"
R2_SECRET_ACCESS_KEY="<r2-secret-access-key>"
R2_BUCKET="co-w-lesie-report-photos"

# E-mail
NEXT_PUBLIC_SITE_CONTACT_EMAIL="kontakt@co-w-lesie.pl"

# Turnstile (Cloudflare CAPTCHA alternative). Public key is safe to expose; secret key is private.
# These defaults are Cloudflare's documented always-pass test keys - replace in production.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Web Push (VAPID) - saved-area hazard alerts. Public key is exposed to the client; keep the
# private key secret. Generate: node -e "console.log(JSON.stringify(require('web-push').generateVAPIDKeys()))"
VAPID_PUBLIC_KEY="<vapid-public-key>"
VAPID_PRIVATE_KEY="<vapid-private-key>"
VAPID_SUBJECT="mailto:kontakt@cowlesie.pl"
